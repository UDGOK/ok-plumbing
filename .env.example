# --- Leads (contact form → email via /api/leads) ---
# Get a key at resend.com. Verify your sending domain to use a custom "from".
RESEND_API_KEY=
LEAD_EMAIL_TO=projects@udgok.com
# Optional verified sender; defaults to Resend's onboarding@resend.dev (test mode).
LEAD_EMAIL_FROM=website@okplumb.com

# Optional: Vercel KV to back rate-limiting for /api/leads and /api/ask
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Ask AI (footer widget → /api/ask) ---
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-haiku-4-5-20251001)
ASK_AI_MODEL=

# --- Google Business Profile (live reviews — Phase 4) ---
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# --- Public site config ---
NEXT_PUBLIC_PHONE=9188518203
NEXT_PUBLIC_LICENSE_NUMBER=
NEXT_PUBLIC_YEARS=
NEXT_PUBLIC_STREET=
NEXT_PUBLIC_ZIP=
NEXT_PUBLIC_GOOGLE_BIZ_URL=
NEXT_PUBLIC_FACEBOOK_URL=

# --- Analytics (optional) ---
NEXT_PUBLIC_GA_ID=
